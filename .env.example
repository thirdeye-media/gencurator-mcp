# Required for the artificial_analysis source.
# Get a free key at https://artificialanalysis.ai/
ARTIFICIAL_ANALYSIS_API_KEY=

# Optional. Only needed if you query gated models on Hugging Face.
HF_TOKEN=

# Optional. "stdio" (default, for Claude Desktop / Claude Code) or "http".
TRANSPORT=stdio

# Optional. Only used when TRANSPORT=http.
PORT=3000
